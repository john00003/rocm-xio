# Build artifacts
build*/
# Exception: scripts/build/ contains build scripts that should be tracked
!scripts/build/
# CTest artifacts (generated when running tests from repo root)
Testing/
bin/
# Local cq-wrap-test binary (legacy name); must not be committed
/cq-wrap-test
lib/
*.o
*.a

# Kernel module build artifacts
kernel/*/*.ko
kernel/*/*.mod
kernel/*/*.mod.c
kernel/*/*.mod.o
kernel/*/Module.symvers
kernel/*/modules.order
kernel/*/.tmp_versions/
kernel/*/.*.cmd
kernel/*/.module-common.o
kernel/*/..module-common.o.cmd
kernel/*/.*.o.d

# Generated files
debian/generated-release-notes.md
cmake/ctest-resources.json
src/include/xio-endpoint-registry-gen.h
src/include/xio-endpoint-includes-gen.h
src/include/nvme-ep-generated.h
src/common/endpoint-dispatch.hip

# Downloaded external headers (can be regenerated with 'make fetch-external-headers')
src/include/external/

# Auto-generated vendor-specific RDMA headers (generated by scripts/generate-rdma-vendor-headers.sh)
src/endpoints/rdma-ep/mlx/mlx5-rdma.h
src/endpoints/rdma-ep/bnxt/bnxt-rdma.h
src/endpoints/rdma-ep/ionic/ionic-rdma.h
src/endpoints/rdma-ep/rocm-ernic/rocm-ernic-rdma.h

# Editor and IDE files
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store

# Compilation database
compile_commands.json

# Log files
*.log

# Emacs temporary files
\#*\#

# rocprofv3 trace output
.rocprofv3/

# Python virtual environment and cache
.venv/
__pycache__/
*.pyc
*.pyo

# LLVM profiling data
default.profraw
